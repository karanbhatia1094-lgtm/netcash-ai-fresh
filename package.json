{
  "name": "netcash-ai-fresh",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remix dev",
    "dev:shopify": "shopify app dev --config shopify.app.netcash-ai-fresh.toml",
    "dev:shopify:localhost": "shopify app dev --config shopify.app.netcash-ai-fresh.toml --use-localhost --localhost-port 3000",
    "build": "remix build",
    "build:prod": "npm run prisma:generate:prod && remix build",
    "start": "remix-serve build/index.js",
    "start:prod": "remix-serve build/index.js",
    "config:staging": "shopify app config use shopify.app.staging.toml",
    "deploy:staging": "shopify app deploy --config shopify.app.staging.toml",
    "worker:once": "node scripts/run-worker-once.mjs",
    "worker:loop": "node scripts/run-worker-loop.mjs",
    "autopilot:enqueue": "node scripts/trigger-autopilot-cron.mjs",
    "loadtest:smoke": "node scripts/loadtest-smoke.mjs",
    "prisma:generate:prod": "npx prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:migrate:prod": "npx prisma migrate deploy --schema prisma/schema.postgres.prisma",
    "prisma:push:prod": "npx prisma db push --schema prisma/schema.postgres.prisma",
    "check:scaling": "node scripts/postgres-ready-check.mjs",
    "check:indexes": "node scripts/verify-postgres-indexes.mjs",
    "check:ops": "node scripts/check-ops-health.mjs",
    "check:go-no-go": "node scripts/go-no-go-gate.mjs",
    "check:prod-bootstrap": "node scripts/prod-bootstrap.mjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "node --test tests",
    "check:preprod": "powershell -ExecutionPolicy Bypass -File ./scripts/preprod-check.ps1",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@shopify/polaris": "^11.0.0",
    "@shopify/shopify-app-remix": "^4.1.1",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.4",
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "@rollup/plugin-json": "^6.1.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^8.54.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.0",
    "typescript": "^5.2.2",
    "vite": "^6.1.6"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "estree-util-value-to-estree": "^3.3.3",
    "tar": "^7.5.7"
  }
}
